---
import type { TreeNode } from "../lib/tree"
import { prevNext } from "../lib/tree"

interface Props {
  root: TreeNode
  node: TreeNode
}
const { root, node } = Astro.props
const { prev, next } = prevNext(root, node)
---

<nav class="mt-10 pt-4 border-t border-gray-200 flex justify-between text-sm">
  <div>
    {
      prev && (
        <a
          href={prev.url}
          class="inline-flex items-center gap-2 text-primary hover:underline"
        >
          <span>←</span>
          <span class="flex flex-col">
            <span class="text-xs text-gray-500">Previous</span>
            <span>{prev.title}</span>
          </span>
        </a>
      )
    }
  </div>
  <div>
    {
      next && (
        <a
          href={next.url}
          class="inline-flex items-center gap-2 text-primary hover:underline text-right"
        >
          <span class="flex flex-col">
            <span class="text-xs text-gray-500">Next</span>
            <span>{next.title}</span>
          </span>
          <span>→</span>
        </a>
      )
    }
  </div>
</nav>
